<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- ============================================================
         URL REWRITE — requires IIS URL Rewrite Module 2.x
         ============================================================ -->
    <rewrite>
      <rules>

        <!-- ── WordPress path redirects (301 Permanent) ── -->

        <rule name="Redirect programs to speeches" stopProcessing="true">
          <match url="^programs/?$" />
          <action type="Redirect" url="/speeches" redirectType="Permanent" />
        </rule>

        <rule name="Redirect category ashok-mahajan to blog" stopProcessing="true">
          <match url="^category/ashok-mahajan/?$" />
          <action type="Redirect" url="/blog" redirectType="Permanent" />
        </rule>

        <rule name="Redirect category covid-india-task-force" stopProcessing="true">
          <match url="^category/covid-india-task-force/?$" />
          <action type="Redirect" url="/covid-india-task-force" redirectType="Permanent" />
        </rule>

        <rule name="Redirect inspirational-quotes to gallery" stopProcessing="true">
          <match url="^inspirational-quotes/?$" />
          <action type="Redirect" url="/gallery" redirectType="Permanent" />
        </rule>

        <rule name="Redirect gallery to messages" stopProcessing="true">
          <match url="^gallery/?$" />
          <action type="Redirect" url="/messages" redirectType="Permanent" />
        </rule>

        <!-- ── Trailing-slash removal (301) for remaining paths ── -->
        <!-- Note: no IsDirectory condition — speeches/, blog/, etc. are real dirs -->

        <rule name="Remove trailing slash" stopProcessing="true">
          <match url="^(.+)/$" />
          <action type="Redirect" url="/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- ── Serve .html files for extensionless URLs ──
             Next.js static export writes out/speeches.html AND out/speeches/ (slugs).
             We skip the IsDirectory check so /speeches → speeches.html even when
             a speeches/ directory also exists on disk.                              -->

        <rule name="Extensionless HTML" stopProcessing="true">
          <match url="^(.+)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}.html" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="{R:1}.html" />
        </rule>

      </rules>
    </rewrite>

    <!-- ============================================================
         DEFAULT DOCUMENT — serve index.html for the root
         ============================================================ -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- ============================================================
         STATIC CONTENT — cache headers for immutable assets
         ============================================================ -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
    </staticContent>

  </system.webServer>
</configuration>
