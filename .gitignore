# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# WordPress uploads (large binary files - copy manually or use CDN in production)
/public/uploads/
/public/inspirational-quotes/

# Local database (do not commit - environment specific)
dev.db
*.db-journal
*.db-wal
*.db-shm

# Deployment snapshot (full build artifacts, not source)
/deploy/

# Build info
*.tsbuildinfo

# PM2 / server runtime files
server.js
